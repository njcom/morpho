#!/usr/bin/env bash

set -eu

readonly SCRIPT_FILE_NAME="$(basename "$0")"
readonly SCRIPT_DIR_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_FILE_PATH="$SCRIPT_DIR_PATH/$SCRIPT_FILE_NAME"

unset _JAVA_OPTIONS
readonly baseDirPath=$(realpath -e $SCRIPT_DIR_PATH/..)
if [[ -e $(echo /usr/share/java/antlr-*-complete.jar | head -1) ]]; then
    readonly antlrJarFilePath=$(echo /usr/share/java/antlr-*-complete.jar | head -1)
else
    readonly antlrJarFilePath="$baseDirPath"/antlr-complete.jar
fi
readonly dstDirPath=$baseDirPath/dst
readonly srcDirPath=$baseDirPath/src
readonly startRule=program
readonly grammar=$(basename $srcDirPath/*Parser* | perl -WpE 's/Parser\.g4$//')

fix() {
    while IFS= read -r -d '' filePath; do
        perl -i -WpE 's~Generated from .*/~Generated from https://github.com/njcom/parser/'"$(basename "$baseDirPath")"'/blob/main/src/~g' "$filePath"
    done < <(find "$(realpath -e "$dstDirPath")" -name '*.java' -type f -print0)
}

setup() {
    if [[ ! -e "$antlrJarFilePath" ]]; then
        curl -sSfL -o "$antlrJarFilePath" https://www.antlr.org/download/antlr-4.9.2-complete.jar
    fi
    if ! command -v antlr4 > /dev/null; then
        local -r antlrBinFilePath=$SCRIPT_DIR_PATH/antlr4
        cat > "$antlrBinFilePath" <<OUT
#!/bin/sh
java -jar "$antlrJarFilePath" "\$@"
OUT
        chmod +x "$antlrBinFilePath"
        export PATH="$(dirname "$antlrBinFilePath")":$PATH
    fi
}

grun() {
    java -cp .:$antlrJarFilePath org.antlr.v4.gui.TestRig "$@"
}

test-all() {
    pushd "$dstDirPath" > /dev/null
    while IFS= read -r -d '' inFilePath; do
        echo "Checking the '$inFilePath'..."
        grun $grammar $startRule -Werror -tree "$inFilePath" &>/dev/null
    done < <(find "$baseDirPath/test" -mindepth 1 -maxdepth 1 -type f -print0)
    popd > /dev/null
}

watch() {
    if [[ $# -lt 1 ]]; then
        echo >&2 Usage: $SCRIPT_FILE_NAME \$makeTarget
        echo >&2 '    where $makeTarget is any target from Makefile'
        exit 1
    fi
    pushd "$baseDirPath" > /dev/null
    # https://superuser.com/questions/181517/how-to-execute-a-command-whenever-a-file-changes
    find -name '*.g4' | entr make "$@"
    popd > /dev/null
}

###############################################################################

usage() {
    echo "Usage: $0 $(_cmdRe | perl -WpE 's/[|()]/\n/g' | perl -WpE 's/^/    /' | sort -u)"
}

_err() {
    >&2 echo "$@"
    exit 1
}

_cmdRe() {
    grep -P '^[a-z].*\(\)\s+{' "$SCRIPT_FILE_PATH" | grep -vP '[A-Z]' | tr -d '() {' | tr '\n' '|' | sed 's/|$//' | sed 's/^/(/' | sed 's/$/)/'
}

if [[ $# -lt 1 ]]; then
    usage
    exit
fi

if [[ ! "$1" =~ ^$(_cmdRe)$ ]]; then
    usage
    exit 1
fi

"$@"
