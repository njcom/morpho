{
    "name": "njcom/morpho",
    "description": "Organizer for developers: project, task and site management system.",
    "type": "library",
    "license": [
        "Apache-2.0"
    ],
    "keywords": [
        "morpho",
        "org",
        "organizer",
        "project-manager",
        "project-management",
        "site-manager",
        "site-management"
    ],
    "require": {
        "njcom/framework": "dev-main"
    },
    "repositories": [
        {
            "type": "vcs",
            "url":  "git@github.com:njcom/framework.git"
        }
    ],
    "autoload": {
        "psr-4": {
            "Njcom\\": "lib/"
        },
        "files": [
            "lib/autoload.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Njcom\\Test\\": "test"
        }
    },
    "config": {
        "discard-changes": true
    },
    "minimum-stability": "dev",
    "extra": {
        "branch-alias": {
            "dev-main": "0.x-dev"
        }
    },
    "support": {
        "issues": "https://github.com/njcom/framework/issues"
    }
}
